# Smriti — environment configuration
# Copy to .env and fill in your values:  cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL (recommended — `make db` starts it via Docker):
DATABASE_URL=postgresql://fieldopt:fieldopt@localhost:5432/fieldopt
# SQLite fallback (no Docker needed — uncomment to use):
# DATABASE_URL=sqlite:///./crewmind.db

# ── Cognee Cloud (the Smriti memory layer) ─────────────────────────
# Get an API key from Cognee Cloud (https://platform.cognee.ai).
# Without these, the base dispatch app still runs, but all
# /api/v1/memory/* endpoints return a clear configuration error.
COGNEE_ENABLED=true
COGNEE_API_KEY=
# URL of your Cognee Cloud instance (cognee.serve() routes all
# remember/recall/improve/forget calls there):
COGNEE_CLOUD_URL=
# Optional: run cognee locally instead of the cloud (leave COGNEE_CLOUD_URL
# empty and provide an LLM key for cognee's local pipeline):
# LLM_API_KEY=
